---
interface LinkItem { href: string; label: string; }
const { currentPath = '', links = [] as LinkItem[] } = Astro.props;
---
<style>
  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    font-size: 20px;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: 6px;
    color: var(--text2);
  }
  .mobile-menu {
    display: none;
    position: fixed;
    top: 48px;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--bg);
    z-index: 99;
    padding: 20px;
    flex-direction: column;
    gap: 4px;
    border-top: 1px solid var(--border);
  }
  .mobile-menu.open { display: flex; }
  @media (max-width: 700px) {
    .mobile-toggle { display: block; }
  }
</style>
<button class="mobile-toggle" aria-label="Meny" aria-expanded="false" onclick="const m=document.getElementById('mobileMenu');m.classList.toggle('open');this.setAttribute('aria-expanded',m.classList.contains('open'))">☰</button>
<div id="mobileMenu" class="mobile-menu" role="navigation" aria-label="Mobil meny">
  {links.map((link: LinkItem) => {
    const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
    return (
      <a href={link.href} style={`font-size:16px;padding:12px 16px;border-radius:8px;text-decoration:none;color:${isActive ? 'var(--accent)' : 'var(--text2)'};font-weight:${isActive ? 600 : 400};`}
        aria-current={isActive ? 'page' : undefined}
        onclick="document.getElementById('mobileMenu').classList.remove('open');document.querySelector('.mobile-toggle').setAttribute('aria-expanded','false')">
        {link.label}
      </a>
    );
  })}
</div>

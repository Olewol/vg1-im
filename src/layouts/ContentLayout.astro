---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { getEmneColor, FAG_LABELS } from '../lib/emneColors';
import kompetansemaalData from '../data/kompetansemaal.json';
import kmKort from '../data/km_kort.json';

interface Props {
  title: string;
  emne: string;
  fag: string;
  uke: number[];
  kompetansemaal: string | string[];
  relatert: string[];
  kilder: string[];
  tags: string[];
}
const { title, emne, fag, uke, kompetansemaal, relatert, kilder, tags } = Astro.props;
const { color, bg } = getEmneColor(fag);
const ukeStr = uke.length === 0 ? null : uke.length > 1 ? `Uke ${uke[0]}–${uke[uke.length - 1]}` : `Uke ${uke[0]}`;
const fagLabel = FAG_LABELS[fag] || fag;

const kmArray = Array.isArray(kompetansemaal) ? kompetansemaal : (kompetansemaal ? [kompetansemaal] : []);
// Show short descriptions by default
const kmKorte = kmArray.map(km => (kmKort as Record<string, string>)[km as string] || kompetansemaalData[km as keyof typeof kompetansemaalData] || km);
// Full text for expandable section
const kmFulltekst = kmArray.map(km => kompetansemaalData[km as keyof typeof kompetansemaalData] || km);
---
<BaseLayout title={title}>
  <article style="max-width:1140px;margin:0 auto;padding:0 32px 80px;">

    <!-- Header -->
    <div style="padding:28px 0 22px;border-bottom:1px solid var(--border);">
      <div style={`display:inline-flex;align-items:center;gap:6px;background:${bg};color:${color};border:1px solid color-mix(in srgb, ${color} 30%, transparent);font-size:12px;font-weight:600;padding:4px 12px;border-radius:20px;margin-bottom:14px;`}>
        {fagLabel}
      </div>
      <h1 style="font-size:28px;font-weight:800;letter-spacing:-.02em;margin-bottom:10px;">{title}</h1>
      <div style="display:flex;align-items:center;gap:18px;flex-wrap:wrap;font-size:13px;color:var(--text2);">
        {ukeStr && <span>📅 Uke: <strong>{ukeStr}</strong></span>}
        {kmKorte.length > 0 && (
          <details style="font-size:13px;">
            <summary style="cursor:pointer;font-weight:600;color:var(--accent);">
              🎯 Kompetansemål ({kmKorte.length})
            </summary>
            <div style="display:flex;flex-direction:column;gap:6px;margin-top:8px;padding:10px 14px;background:var(--surface);border:1px solid var(--border);border-radius:8px;">
              {kmKorte.map((kort, i) => (
                <div style="display:flex;flex-direction:column;gap:2px;">
                  <span style="font-weight:600;">🎯 {kort}</span>
                  <span style="font-size:12px;color:var(--text3);padding-left:22px;">{kmFulltekst[i]}</span>
                </div>
              ))}
            </div>
          </details>
        )}
      </div>
    </div>

    <!-- Two-column body -->
    <div style="display:grid;grid-template-columns:1fr 260px;gap:0;">
      <div id="mainContent" class="prose" style="padding:28px 32px 28px 0;border-right:1px solid var(--border);">
        <slot />
      </div>
      <Sidebar
        relatert={relatert}
        kilder={kilder}
        tags={tags}
        emne={emne}
        fag={fag}
      />
    </div>

    <!-- Kildehenvisninger -->
    {kilder.length > 0 && (
      <div style="margin-top:40px;padding-top:24px;border-top:1px solid var(--border);font-size:13px;color:var(--text3);">
        <strong>Kilder:</strong>
        <ul style="margin-top:8px;">
          {kilder.map(k => (
            k.startsWith('http') 
              ? <li><a href={k} target="_blank" rel="noopener noreferrer">{k} <span style="font-size:11px;">(åpnes i ny fane)</span></a></li>
              : <li>{k}</li>
          ))}
        </ul>
      </div>
    )}
  </article>
</BaseLayout>
